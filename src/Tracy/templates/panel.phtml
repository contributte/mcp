 * @var \Mcp\Schema\Page $resources
 * @var \Mcp\Schema\Page $resourceTemplates
 * @var \Mcp\Schema\Page $prompts
 */

$formatHandler = static function (mixed $handler): string {
	if (is_array($handler) && count($handler) === 2) {
		$class = is_object($handler[0]) ? get_class($handler[0]) : (string) $handler[0];

		return $class . '::' . $handler[1] . '()';
	}

	if (is_string($handler)) {
		return $handler;
	}

	return '';
};

